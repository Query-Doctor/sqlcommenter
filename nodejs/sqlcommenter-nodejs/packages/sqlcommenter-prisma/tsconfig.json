{
  "compilerOptions": {
    "target": "es2018",
    "lib": ["es2022"],
    "module": "es2020",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist/esm",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": ["test", "dist", "node_modules"]
}
